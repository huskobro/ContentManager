# ─────────────────────────────────────────────────────
# ContentManager — Ortam Değişkenleri Şablonu
# Bu dosyayı kopyalayıp ".env" adıyla kaydedin:
#   cp .env.example .env
# Gerçek API anahtarlarınızı .env'e girin.
# .env GİTİGNORE'DA OLMALI — asla commit etmeyin.
# ─────────────────────────────────────────────────────

# ── Uygulama ──────────────────────────────────────────
APP_NAME=ContentManager
APP_VERSION=0.1.0
ENVIRONMENT=development        # development | production

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_RELOAD=true

# Virgülle ayrılmış CORS origin listesi
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Admin panel PIN — mutlaka değiştirin!
ADMIN_PIN=0000

# ── Pipeline Limitleri ────────────────────────────────
MAX_CONCURRENT_JOBS=2
JOB_TIMEOUT_SECONDS=1800

# ── Video Çıktısı ─────────────────────────────────────
# Tamamlanan videoların kaydedileceği klasör
# Yapılacak: Admin panel'den dinamik olarak değiştirebilir hale getir
OUTPUT_DIR=./output

# ── Pipeline Varsayılanları ───────────────────────────
DEFAULT_LANGUAGE=tr
DEFAULT_TTS_PROVIDER=edge_tts
DEFAULT_LLM_PROVIDER=kieai
DEFAULT_VISUALS_PROVIDER=pexels
DEFAULT_VIDEO_RESOLUTION=1920x1080
DEFAULT_VIDEO_FPS=30
DEFAULT_SUBTITLE_STYLE=standard

# ── LLM Provider API Anahtarları ─────────────────────
GEMINI_API_KEY=
KIEAI_API_KEY=
OPENAI_API_KEY=

# ── TTS Provider API Anahtarları ─────────────────────
ELEVENLABS_API_KEY=

# ── Görsel Provider API Anahtarları ──────────────────
PEXELS_API_KEY=
PIXABAY_API_KEY=

# ── YouTube OAuth ─────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
